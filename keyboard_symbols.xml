<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button android:id="@+id/key_1" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="1" android:tag="key:1"/>
        <Button android:id="@+id/key_2" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="2" android:tag="key:2"/>
        <Button android:id="@+id/key_3" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="3" android:tag="key:3"/>
        <Button android:id="@+id/key_4" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="4" android:tag="key:4"/>
        <Button android:id="@+id/key_5" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="5" android:tag="key:5"/>
        <Button android:id="@+id/key_6" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="6" android:tag="key:6"/>
        <Button android:id="@+id/key_7" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="7" android:tag="key:7"/>
        <Button android:id="@+id/key_8" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="8" android:tag="key:8"/>
        <Button android:id="@+id/key_9" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="9" android:tag="key:9"/>
        <Button android:id="@+id/key_0" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="0" android:tag="key:0"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <Button android:id="@+id/key_exclam" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="!" android:tag="key:!"/>
        <Button android:id="@+id/key_at" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="@" android:tag="key:@"/>
        <Button android:id="@+id/key_hash" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="#" android:tag="key:#"/>
        <Button android:id="@+id/key_dollar" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="$" android:tag="key:$"/>
        <Button android:id="@+id/key_percent" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="%" android:tag="key:%"/>
        <Button android:id="@+id/key_amp" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="&amp;" android:tag="key:&amp;"/>
        <Button android:id="@+id/key_star" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="*" android:tag="key:*"/>
        <Button android:id="@+id/key_paren_open" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="(" android:tag="key:("/>
        <Button android:id="@+id/key_paren_close" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text=")" android:tag="key:)"/>
        <Button android:id="@+id/key_delete" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1.2" android:text="⌫" android:tag="delete"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <Button android:id="@+id/key_qwerty" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1.2" android:text="ABC" android:tag="qwerty"/>
        <Button android:id="@+id/key_clipboard" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1.2" android:text="Clip" android:tag="clipboard"/>
        <Button android:id="@+id/key_space" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="4" android:text="space" android:tag="space"/>
        <Button android:id="@+id/key_enter" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1.3" android:text="↵" android:tag="enter"/>
    </LinearLayout>

</LinearLayout>
