<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboardHost"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="6dp">

    <LinearLayout
        android:id="@+id/toolbarRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="6dp">

        <Button
            android:id="@+id/btnClipboardPanel"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:text="Clipboard"
            android:tag="toolbar_clipboard" />

        <Button
            android:id="@+id/btnEmojiPanel"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:text="😊"
            android:tag="toolbar_emoji" />

        <Button
            android:id="@+id/btnSwitchToLetters"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:text="ABC"
            android:tag="qwerty" />

        <Button
            android:id="@+id/btnSwitchToSymbols"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:text="?123"
            android:tag="symbol" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnOpenSettings"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:text="⚙"
            android:tag="settings" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/panelContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/txtPanelTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Panel"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnClosePanel"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:minWidth="0dp"
                android:text="×"
                android:tag="panel_close" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/panelClipboard"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/clipboardList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <ScrollView
            android:id="@+id/panelEmoji"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:visibility="gone">

            <GridLayout
                android:id="@+id/emojiGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="8"
                android:padding="2dp" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutQwerty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include layout="@layout/keyboard_qwerty" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutSymbols"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <include layout="@layout/keyboard_symbols" />
    </LinearLayout>
</LinearLayout>
